{
  "name": "alazab-dev",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Advanced Tech Solutions for construction and architectural projects",
  "author": "alazab.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alazab-dev/website"
  },
  "keywords": [
    "react",
    "vite",
    "typescript",
    "pwa",
    "tailwindcss",
    "shadcn-ui"
  ],
  "scripts": {
    "dev": "vite --mode development",
    "build": "npm run type-check && vite build --mode production",
    "build:dev": "vite build --mode development",
    "build:analyze": "vite build --mode production && npx vite-bundle-visualizer",
    "preview": "vite preview",
    "preview:prod": "npm run build && vite preview --mode production",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "clean": "rm -rf node_modules package-lock.json dist .cache",
    "clean:install": "npm run clean && npm install",
    "update": "npx npm-check-updates -u && npm install",
    "update:minor": "npx npm-check-updates -u --target minor && npm install",
    "update:patch": "npx npm-check-updates -u --target patch && npm install",
    "security-check": "npm audit --production",
    "security-fix": "npm audit fix --production"
  },
  "dependencies": {
